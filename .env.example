# Copy to .env and fill in real values. Never commit .env.

# Firebase — get from Firebase Console > Project Settings > Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Claude API — https://console.anthropic.com/
VITE_CLAUDE_API_KEY=
VITE_CLAUDE_MODEL=claude-opus-4-6

# OpenAI — https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o

# LinkedIn — https://developer.linkedin.com/
VITE_LINKEDIN_ACCESS_TOKEN=
VITE_LINKEDIN_PERSON_URN=urn:li:person:YOUR_PERSON_ID

# WordPress REST API — Settings > Application Passwords
VITE_WP_URL=https://yourblog.com
VITE_WP_USERNAME=
VITE_WP_APP_PASSWORD=
